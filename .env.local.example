# Turso libSQL connection
# Production: get from `turso db show forge-prod --url` (libsql://...turso.io)
# Local dev (no Turso account needed): set to "file:./local.db"
TURSO_DATABASE_URL=libsql://forge-prod-<your-name>.turso.io

# Production: get from `turso db tokens create forge-prod`
# Local file DB: leave blank
TURSO_AUTH_TOKEN=
